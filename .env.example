# NoneBot2 监听地址
# 一般和你现有 OneBot / NapCat 反向连接配置保持一致
HOST=127.0.0.1
PORT=8080

# TS3 语音服务器地址
# 示例使用本地地址，实际也可填写公网域名或 IP
TS3_TRACKER__SERVER_HOST=127.0.0.1

# TS3 语音端口，默认通常为 9987
TS3_TRACKER__SERVER_PORT=9987

# TS3 ServerQuery 端口，默认通常为 10011
TS3_TRACKER__SERVERQUERY_PORT=10011

# TS3 ServerQuery 登录账号
# 示例请改成你自己的查询账号
TS3_TRACKER__SERVERQUERY_USERNAME=your-serverquery-username

# TS3 ServerQuery 登录密码
TS3_TRACKER__SERVERQUERY_PASSWORD=your-password

# 是否输出调试日志
# true = 输出更多调试信息
# false = 使用正常日志
TS3_TRACKER__DEBUG=false

# 命令优先级，默认 10
# 数值越小优先级越高
TS3_TRACKER__COMMAND_PRIORITY=10

# 单次查询超时时间，单位秒
TS3_TRACKER__QUERY_TIMEOUT_SECONDS=10

# 是否开启 TS3 进服 / 退服通知
# true = 开启通知
# false = 仅保留查询功能
TS3_TRACKER__NOTIFICATION_ENABLED=true

# 接收通知的群号
# 支持逗号、分号或换行分隔多个群号
TS3_TRACKER__NOTIFY_TARGET_GROUPS=123456789

# 接收通知的私聊 QQ
# 不需要可留空
TS3_TRACKER__NOTIFY_TARGET_USERS=

# 指定发送通知使用的 OneBot V11 Bot ID
# 不填写则自动选择当前可用 Bot
TS3_TRACKER__NOTIFY_BOT_ID=

# 是否开启群白名单模式
# true = 只有白名单群可用群聊查询，且只有白名单群会收到群通知
# false = 所有群聊都可以查询
TS3_TRACKER__GROUP_WHITELIST_ENABLED=false

# 群白名单列表
# 支持逗号、分号或换行分隔多个群号
TS3_TRACKER__GROUP_WHITELIST_GROUPS=

# TS3 在线状态轮询间隔，单位秒
# 当前项目默认建议为 5 秒
TS3_TRACKER__POLL_INTERVAL_SECONDS=5

# 启动时是否静默同步快照
# true = 启动时不同步历史进退服消息，只建立当前在线快照
# false = 启动后立即根据差异发送通知
TS3_TRACKER__STARTUP_SILENT=true

# 插件快照数据目录
# 用于保存在线用户首次出现时间等状态
# 不填写时默认使用 nonebot-plugin-localstore 提供的插件数据目录
TS3_TRACKER__DATA_DIR=data/ts3_tracker
